{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "RemitFlex",
  "colors": {
    "primary": "#ef7025",
    "light": "#eec9bc",
    "dark": "#4fa1ab"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "openapi": "openapi.yaml",
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["bash", "javascript", "python"],
      "defaults": "required",
      "prefill": false,
      "autogenerate": true
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@remitflex.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.remitflex.io"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "concepts/platform",
              "concepts/stablecoins",
              "concepts/african-corridors"
            ]
          },
          {
            "group": "Swaps",
            "pages": [
              "products/swaps"
            ]
          },
          {
            "group": "Payment routes",
            "pages": [
              "products/payment-routes"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "products/customers"
            ]
          },
          {
            "group": "Ledger",
            "pages": [
              "products/transactions",
              "products/rates"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "configuration/environments",
              "guides/testing",
              "configuration/error-codes"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/idempotency",
              "api-reference/pagination"
            ]
          },
          {
            "group": "Rates",
            "pages": [
              "GET /rates",
              "GET /rates/currencies",
              "GET /rates/{from}/{to}"
            ]
          },
          {
            "group": "Swaps",
            "pages": [
              "GET /swaps",
              "POST /swaps",
              "GET /swaps/{id}",
              "POST /swaps/{id}/cancel"
            ]
          },
          {
            "group": "Payment routes",
            "pages": [
              "GET /payment-routes/chains",
              "GET /payment-routes/corridors",
              "GET /payment-routes/currencies",
              "GET /payment-routes",
              "POST /payment-routes",
              "GET /payment-routes/deposits",
              "GET /payment-routes/{id}",
              "GET /payment-routes/{id}/deposits",
              "POST /payment-routes/{id}/deposits/sync",
              "POST /payment-routes/{id}/pause",
              "POST /payment-routes/{id}/activate",
              "DELETE /payment-routes/{id}"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "GET /customers",
              "POST /customers"
            ]
          },
          {
            "group": "Transactions",
            "pages": [
              "GET /transactions"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/remitflex",
      "linkedin": "https://linkedin.com/company/remitflex"
    }
  }
}
