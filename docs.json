{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Remitflex",
  "colors": {
    "primary": "#0F766E",
    "light": "#14B8A6",
    "dark": "#0D9488"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "openapi": "openapi.yaml",
    "url": "full",
    "playground": {
      "display": "interactive",
      "proxy": false,
      "credentials": true
    },
    "examples": {
      "languages": [
        "bash",
        "javascript",
        "python"
      ],
      "defaults": "required",
      "prefill": false,
      "autogenerate": true
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@remitflex.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.remitflex.io"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "products/customers"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "concepts/platform",
              "concepts/stablecoins"
            ]
          },
          {
            "group": "Networks & corridors",
            "pages": [
              "concepts/networks-and-corridors",
              "concepts/african-corridors"
            ]
          },
          {
            "group": "Collect payments",
            "pages": [
              "products/payment-links",
              "products/payment-routes"
            ]
          },
          {
            "group": "Local fiat",
            "pages": [
              "products/fiat-rails"
            ]
          },
          {
            "group": "Swaps",
            "pages": [
              "products/swaps",
              "products/ngn-rails"
            ]
          },
          {
            "group": "Ledger",
            "pages": [
              "products/transactions"
            ]
          },
          {
            "group": "Rates",
            "pages": [
              "products/rates"
            ]
          },
          {
            "group": "Integration",
            "pages": [
              "configuration/environments",
              "guides/webhooks",
              "guides/testing",
              "configuration/error-codes"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/idempotency",
              "api-reference/pagination"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "GET /customers",
              "POST /customers"
            ]
          },
          {
            "group": "Networks & corridors",
            "pages": [
              "GET /payment-routes/chains",
              "GET /payment-routes/corridors",
              "GET /payment-routes/currencies",
              "GET /collections/chains",
              "GET /collections/corridors"
            ]
          },
          {
            "group": "Payment routes",
            "pages": [
              "GET /payment-routes",
              "POST /payment-routes",
              "GET /payment-routes/deposits",
              "GET /payment-routes/{id}",
              "GET /payment-routes/{id}/deposits",
              "POST /payment-routes/{id}/deposits/sync",
              "POST /payment-routes/{id}/pause",
              "POST /payment-routes/{id}/activate",
              "DELETE /payment-routes/{id}"
            ]
          },
          {
            "group": "Payment links",
            "pages": [
              "GET /collections",
              "POST /collections",
              "GET /collections/{id}",
              "PATCH /collections/{id}",
              "POST /collections/{id}/sync",
              "POST /collections/{id}/cancel",
              "POST /collections/{id}/logo",
              "PATCH /collections/{id}/embed-config",
              "GET /pay/{id}/embed-config",
              "GET /pay/{id}",
              "GET /pay/{id}/logo",
              "POST /pay/{id}/quote"
            ]
          },
          {
            "group": "Local fiat",
            "pages": [
              {
                "group": "Offramps",
                "pages": [
                  "GET /offramps",
                  "POST /offramps",
                  "GET /offramps/{orderId}",
                  "PATCH /offramps/{orderId}/external-transfer",
                  "DELETE /offramps/{orderId}",
                  "GET /offramps/by-external-transfer/{externalTransferId}"
                ]
              },
              {
                "group": "Onramps",
                "pages": [
                  "GET /onramps",
                  "POST /onramps",
                  "GET /onramps/{orderId}"
                ]
              },
              {
                "group": "Reference data",
                "pages": [
                  "GET /fiat/currencies",
                  "GET /fiat/institutions/{currencyCode}",
                  "POST /fiat/verify-account",
                  "GET /fiat/rates/{token}/{amount}/{currency}"
                ]
              }
            ]
          },
          {
            "group": "Swap rates (Solana)",
            "pages": [
              "GET /rates",
              "GET /rates/currencies",
              "GET /rates/{from}/{to}"
            ]
          },
          {
            "group": "Swaps",
            "pages": [
              "GET /swaps",
              "POST /swaps",
              "GET /swaps/{id}",
              "POST /swaps/{id}/cancel"
            ]
          },
          {
            "group": "NGN rails",
            "pages": [
              "GET /rails/swaps",
              "POST /rails/swaps",
              "GET /rails/swaps/{id}",
              "GET /rails/withdrawals",
              "POST /rails/withdrawals",
              "GET /rails/withdrawals/{id}",
              "GET /rails/banks",
              "POST /rails/offramps/resolve-account",
              "GET /rails/offramps",
              "POST /rails/offramps",
              "GET /rails/offramps/{id}",
              "GET /rails/onramps",
              "POST /rails/onramps",
              "GET /rails/onramps/{id}",
              "POST /rails/onramps/{id}/consolidate"
            ]
          },
          {
            "group": "Transactions",
            "pages": [
              "GET /transactions"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "GET /webhooks/event-types",
              "GET /webhooks",
              "POST /webhooks",
              "GET /webhooks/{id}",
              "PATCH /webhooks/{id}",
              "DELETE /webhooks/{id}",
              "POST /webhooks/{id}/rotate-secret",
              "GET /webhooks/{id}/deliveries",
              "POST /webhooks/{id}/test"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/products/collections",
      "destination": "/products/payment-links",
      "permanent": true
    },
    {
      "source": "/products/embed-widget",
      "destination": "/products/payment-links#embed",
      "permanent": true
    },
    {
      "source": "/guides/testing-collections",
      "destination": "/guides/testing",
      "permanent": true
    },
    {
      "source": "/guides/testing-payment-links",
      "destination": "/guides/testing",
      "permanent": true
    }
  ],
  "footer": {
    "socials": {
      "x": "https://x.com/remitflex",
      "linkedin": "https://linkedin.com/company/remitflex"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "Remitflex Docs",
      "og:title": "Remitflex Documentation",
      "twitter:title": "Remitflex Documentation"
    }
  }
}
